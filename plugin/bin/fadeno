var import_meta = {};
var moduleDir = typeof __dirname === "string" ? __dirname : (0, import_node_path.dirname)((0, import_node_url.fileURLToPath)(import_meta.url));
function findUp(name, startDir) {
  let dir = (0, import_node_path.resolve)(startDir);
  for (; ; ) {
    const candidate = (0, import_node_path.join)(dir, name);
    if ((0, import_node_fs.existsSync)(candidate)) return candidate;
    const parent = (0, import_node_path.dirname)(dir);
    if (parent === dir) return null;
    dir = parent;
  }
}
function templatesDir() {
  const candidates = [
    (0, import_node_path.resolve)(moduleDir, "templates"),
    // bundled binary: <bin>/templates (plugin/bin)
    (0, import_node_path.resolve)(moduleDir, "../templates"),
    (0, import_node_path.resolve)(moduleDir, "../../templates")
    // dev (src/lib) and built (dist/lib)
  ];
  for (const candidate of candidates) {
    if ((0, import_node_fs.existsSync)(candidate)) return candidate;
  }
  const pkg = findUp("package.json", moduleDir);
  if (pkg) {
    const beside = (0, import_node_path.join)((0, import_node_path.dirname)(pkg), "templates");
    if ((0, import_node_fs.existsSync)(beside)) return beside;
  }
  throw new Error(
    "Could not locate the Fadeno templates directory. Is the package installed correctly?"
  );
}
function findRepoRoot(startDir = process.cwd()) {
  const gitPath = findUp(".git", startDir);
  if (gitPath) return (0, import_node_path.dirname)(gitPath);
  return (0, import_node_path.resolve)(startDir);
}
function packageVersion() {
  if (true) return "0.4.0";
  const pkgPath = findUp("package.json", moduleDir);
  if (!pkgPath) return "0.0.0";
  try {
    const raw = (0, import_node_fs.readFileSync)(pkgPath, "utf8");
    const parsed = JSON.parse(raw);
    return parsed.version ?? "0.0.0";
  } catch {
    return "0.0.0";
  }
}

// src/commands/diagram.ts
var DiagramError = class extends Error {
};
function resolvePlaybookFile(repoRoot, cwd, ref) {
  if ((0, import_node_path2.isAbsolute)(ref) || ref.includes("/") || /\.ya?ml$/i.test(ref)) {
    const direct = (0, import_node_path2.isAbsolute)(ref) ? ref : (0, import_node_path2.resolve)(cwd, ref);
    if ((0, import_node_fs2.existsSync)(direct)) return direct;
  }
  const stripped = ref.replace(/\.(ya?ml)$/i, "");
  for (const candidate of [`${stripped}.yaml`, `${stripped}.yml`]) {
    const path = (0, import_node_path2.join)(repoRoot, ".fadeno", "playbooks", candidate);
    if ((0, import_node_fs2.existsSync)(path)) return path;
  }
  throw new DiagramError(`Playbook "${ref}" not found (looked under .fadeno/playbooks).`);
}
function runDiagram(opts) {
  const cwd = opts.cwd ?? process.cwd();
  const repoRoot = opts.repoRoot ?? findRepoRoot(cwd);
  const file = resolvePlaybookFile(repoRoot, cwd, opts.playbook);
  let doc;
  try {
    doc = (0, import_yaml.parse)((0, import_node_fs2.readFileSync)(file, "utf8"));
  } catch (err) {
    throw new DiagramError(`Could not parse ${file}: ${err.message}`);
  }
  if (doc === null || typeof doc !== "object" || Array.isArray(doc) || !Array.isArray(doc.flow)) {
    throw new DiagramError(`${file} is not a playbook (missing a flow list).`);
  }
  return renderDiagram(doc, opts.format ?? "ascii");
}

