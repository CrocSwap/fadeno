var import_node_fs9 = require("node:fs");
var import_node_path9 = require("node:path");
var import_yaml5 = __toESM(require_dist(), 1);
var RunLedgerError = class extends Error {
};
function stringOrNull(value) {
  return typeof value === "string" ? value : null;
}
function summarizeRunDir(runId, dir) {
  const yamlPath = (0, import_node_path9.join)(dir, "run.yaml");
  const base = {
    runId,
    dir,
    playbook: null,
    status: null,
    task: null,
    host: null,
    startedAt: null,
    endedAt: null,
    problems: []
  };
  let raw;
  try {
    raw = (0, import_node_fs9.readFileSync)(yamlPath, "utf8");
  } catch (err) {
    base.problems.push(`unreadable run.yaml: ${err.message}`);
    return base;
  }
  let parsed;
  try {
    parsed = (0, import_yaml5.parse)(raw);
  } catch (err) {
    base.problems.push(`unparseable run.yaml: ${err.message}`);
    return base;
  }
  if (parsed === null || typeof parsed !== "object" || Array.isArray(parsed)) {
    base.problems.push("unparseable run.yaml: not an object");
    return base;
  }
  const doc = parsed;
  base.playbook = stringOrNull(doc.playbook);
  base.status = stringOrNull(doc.status);
  base.task = stringOrNull(doc.task);
  base.host = stringOrNull(doc.host);
  base.startedAt = stringOrNull(doc.started_at);
  base.endedAt = stringOrNull(doc.ended_at);
  return base;
}
function listRuns(repoRoot) {
  const runsDir = (0, import_node_path9.join)(repoRoot, ".fadeno", "runs");
  if (!(0, import_node_fs9.existsSync)(runsDir)) return [];
  const entries = (0, import_node_fs9.readdirSync)(runsDir, { withFileTypes: true });
  const runs = [];
  for (const entry of entries) {
    if (!entry.isDirectory()) continue;
    const dir = (0, import_node_path9.join)(runsDir, entry.name);
    if (!(0, import_node_fs9.existsSync)((0, import_node_path9.join)(dir, "run.yaml"))) continue;
    runs.push(summarizeRunDir(entry.name, dir));
  }
  runs.sort((a, b) => a.runId < b.runId ? 1 : a.runId > b.runId ? -1 : 0);
  return runs;
}
function readEvents(runDir) {
  const path = (0, import_node_path9.join)(runDir, "events.jsonl");
  if (!(0, import_node_fs9.existsSync)(path)) return { events: [], badLines: [] };
  const text = (0, import_node_fs9.readFileSync)(path, "utf8");
  const lines = text.split("\n");
  const events = [];
  const badLines = [];
  for (let i = 0; i < lines.length; i += 1) {
    const line = lines[i];
    if (line.trim() === "") continue;
    const lineNo = i + 1;
    let parsed;
    try {
      parsed = JSON.parse(line);
    } catch {
      badLines.push(lineNo);
      continue;
    }
    if (parsed === null || typeof parsed !== "object" || Array.isArray(parsed)) {
      badLines.push(lineNo);
      continue;
    }
    const obj = parsed;
    const type = typeof obj.type === "string" ? obj.type : "unknown";
    const step = stringOrNull(obj.step);
    const timestamp = stringOrNull(obj.timestamp);
    const extra = {};
    for (const [key, value] of Object.entries(obj)) {
      if (key === "type" || key === "step" || key === "timestamp") continue;
      extra[key] = value;
    }
    events.push({ type, step, timestamp, extra });
  }
  return { events, badLines };
}
function readEventsStrict(runDir) {
  const { events, badLines } = readEvents(runDir);
  if (badLines.length > 0) {
    throw new RunLedgerError(`events.jsonl has malformed lines: ${badLines.join(", ")}`);
  }
  return events;
}
function resolveRun(repoRoot, query) {
  const runs = listRuns(repoRoot);
  const exact = runs.find((r) => r.runId === query);
  if (exact) return exact;
  const matches = runs.filter((r) => r.runId.startsWith(query));
  if (matches.length === 1) return matches[0];
  if (matches.length === 0) {
    throw new RunLedgerError(`No run matching "${query}" under .fadeno/runs.`);
  }
  const listed = matches.slice(0, 5).map((r) => r.runId).join(", ");
  const more = matches.length > 5 ? `, \u2026(+${matches.length - 5} more)` : "";
  throw new RunLedgerError(`Multiple runs match "${query}": ${listed}${more}.`);
}
function listArtifacts(runDir) {
  const artifactsDir = (0, import_node_path9.join)(runDir, "artifacts");
  if (!(0, import_node_fs9.existsSync)(artifactsDir)) return [];
  const out = [];
  function walk(dir) {
    for (const entry of (0, import_node_fs9.readdirSync)(dir, { withFileTypes: true })) {
      const full = (0, import_node_path9.join)(dir, entry.name);
      if (entry.isDirectory()) {
        walk(full);
      } else if (entry.isFile()) {
        out.push({
          path: (0, import_node_path9.relative)(runDir, full).split("\\").join("/"),
          bytes: (0, import_node_fs9.statSync)(full).size
        });
      }
    }
  }
  walk(artifactsDir);
  out.sort((a, b) => a.path < b.path ? -1 : a.path > b.path ? 1 : 0);
  return out;
}

// src/commands/next.ts
var NextError = class extends Error {
};
function locatePlaybook(repoRoot, name) {
  const dir = (0, import_node_path10.join)(repoRoot, ".fadeno", "playbooks");
  for (const candidate of [`${name}.yaml`, `${name}.yml`]) {
    const path = (0, import_node_path10.join)(dir, candidate);
    if ((0, import_node_fs10.existsSync)(path)) return path;
  }
  throw new NextError(`Playbook "${name}" not found in ${dir}.`);
}
function runNext(opts) {
  const cwd = opts.cwd ?? process.cwd();
  const repoRoot = opts.repoRoot ?? findRepoRoot(cwd);
  let run;
  try {
    run = resolveRun(repoRoot, opts.run);
  } catch (err) {
    if (err instanceof RunLedgerError) throw new NextError(err.message);
    throw err;
  }
  if (run.playbook == null) {
    throw new NextError(`run "${run.runId}" has no playbook recorded in run.yaml.`);
  }
  if (run.status != null && run.status !== "running") {
    return {
      run: run.runId,
      playbook: run.playbook,
      status: "terminal",
      step: null,
      gate: null,
      human_gate: null,
      terminal: { status: run.status, step: null },
      advice: `run is terminal (${run.status}); return the final summary.`
    };
  }
  let events;
  try {
    events = readEventsStrict(run.dir);
  } catch (err) {
    if (err instanceof RunLedgerError) throw new NextError(err.message);
    throw err;
  }
  const playbookPath = locatePlaybook(repoRoot, run.playbook);
  let playbook;
  try {
    const parsed = (0, import_yaml6.parse)((0, import_node_fs10.readFileSync)(playbookPath, "utf8"));
    if (parsed == null || typeof parsed !== "object" || Array.isArray(parsed)) {
      throw new Error("playbook is not a mapping");
    }
    playbook = parsed;
  } catch (err) {
    throw new NextError(`could not parse playbook ${run.playbook}: ${err.message}`);
  }
  const schemas = new SchemaSet((0, import_node_path10.join)(repoRoot, ".fadeno", "schemas"));
  const validation = validateFile(playbookPath, schemas, "playbook");
  const errorIssues = validation.issues.filter((issue) => issue.severity === "error");
  if (errorIssues.length > 0) {
    const detail2 = errorIssues.map((issue) => `${issue.path || "/"}: ${issue.message}`).join("; ");
    throw new NextError(`playbook ${run.playbook} is invalid; fix it before asking for the next step: ${detail2}`);
  }
  let computation;
  try {
    computation = computeNext(playbook, events);
  } catch (err) {
    if (err instanceof FlowCursorError) throw new NextError(err.message);
    throw err;
  }
  return {
    run: run.runId,
    playbook: typeof playbook.name === "string" ? playbook.name : run.playbook,
    ...computation
  };
}

