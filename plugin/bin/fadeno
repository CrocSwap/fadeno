    prompt_sha256: promptSha,
    prompt_path: promptRel,
    manifest_version: 1,
    timestamp: now.toISOString()
  };
  (0, import_node_fs11.appendFileSync)((0, import_node_path11.join)(runDir, "events.jsonl"), `${JSON.stringify(manifest)}
`, "utf8");
  return { prompt, sha256: promptSha, promptPath: promptRel, recorded: "created", plan };
}

// src/commands/run.ts
var import_node_fs12 = require("node:fs");
var import_node_path12 = require("node:path");
var import_yaml8 = __toESM(require_dist(), 1);
var RunError = class extends Error {
};
var TERMINAL_STATUSES = /* @__PURE__ */ new Set(["completed", "failed", "aborted"]);
var VALID_STATUSES = /* @__PURE__ */ new Set(["running", ...TERMINAL_STATUSES]);
var RUN_YAML_MODELINE = "# yaml-language-server: $schema=../../schemas/run.schema.json";
function resolveRunDir2(repoRoot, cwd, run) {
  const candidates = (0, import_node_path12.isAbsolute)(run) ? [run] : [(0, import_node_path12.join)(repoRoot, ".fadeno", "runs", run), (0, import_node_path12.resolve)(cwd, run)];
  for (const candidate of candidates) {
    const dir = candidate.endsWith("run.yaml") ? candidate.slice(0, -"run.yaml".length) : candidate;
    if ((0, import_node_fs12.existsSync)((0, import_node_path12.join)(dir, "run.yaml"))) return dir;
  }
  throw new RunError(`No run found for "${run}" (looked for run.yaml under .fadeno/runs).`);
}
function parseFieldValue(raw) {
  const trimmed = raw.trim();
  if (trimmed === "") return "";
  try {
    return JSON.parse(trimmed);
  } catch {
    return raw;
  }
}
function parseFields(fields) {
  if (!fields || fields.length === 0) return {};
  const out = {};
  for (const entry of fields) {
    const eq = entry.indexOf("=");
    if (eq <= 0) {
      throw new RunError(`Invalid --field "${entry}"; expected k=v (e.g. branch=approve).`);
    }
    const key = entry.slice(0, eq).trim();
    const value = entry.slice(eq + 1);
    if (!key) {
      throw new RunError(`Invalid --field "${entry}"; expected k=v (e.g. branch=approve).`);
    }
    out[key] = parseFieldValue(value);
  }
  return out;
}
function runRun(opts) {
  const extraFields = parseFields(opts.fields);
  const hasAttribution = opts.member != null || Object.keys(extraFields).length > 0;
  if (!opts.step && !opts.status && !opts.event && !opts.artifact && !hasAttribution) {
    throw new RunError("Nothing to do: pass --step, --status, --event, and/or --artifact.");
  }
  if (hasAttribution && !opts.event && !opts.artifact && !opts.step && !opts.status) {
    throw new RunError("--member / --field require an event to attach to (--event and/or --artifact).");
  }
  const cwd = opts.cwd ?? process.cwd();
  const repoRoot = opts.repoRoot ?? findRepoRoot(cwd);
  const runDir = resolveRunDir2(repoRoot, cwd, opts.run);
  const runYamlPath = (0, import_node_path12.join)(runDir, "run.yaml");
  const eventsPath = (0, import_node_path12.join)(runDir, "events.jsonl");
  const run = (0, import_yaml8.parse)((0, import_node_fs12.readFileSync)(runYamlPath, "utf8"));
  const iso = (opts.now ?? /* @__PURE__ */ new Date()).toISOString();
  const appendedEvents = [];
  const updatedFields = [];
  const appendEvent = (event) => {
    (0, import_node_fs12.appendFileSync)(eventsPath, `${JSON.stringify({ ...event, timestamp: iso })}
`, "utf8");
    appendedEvents.push(event.type);
  };
  if (opts.step) {
    run.current_step = opts.step;
    updatedFields.push("current_step");
    appendEvent({ type: "step_started", step: opts.step });
  }
  const eventStep = opts.step ?? (run.current_step ?? null);
  const attachAttribution = (event) => {
    if (opts.member != null) event.member = opts.member;
    for (const [key, value] of Object.entries(extraFields)) {
      event[key] = value;
    }
  };
  if (opts.event) {
    const event = { type: opts.event, step: eventStep };
    if (opts.artifact) event.artifact = opts.artifact;
    attachAttribution(event);
    appendEvent(event);
  } else if (opts.artifact) {
    const event = {
      type: "artifact_created",
      step: eventStep,
      artifact: opts.artifact
    };
    attachAttribution(event);
    appendEvent(event);
  } else if (hasAttribution) {
    throw new RunError("--member / --field require an event to attach to (--event and/or --artifact).");
  }
  if (opts.status) {
    if (!VALID_STATUSES.has(opts.status)) {
      throw new RunError(
        `Invalid status "${opts.status}". Use one of: ${[...VALID_STATUSES].join(", ")}.`
      );
    }
    run.status = opts.status;
    updatedFields.push("status");
    if (TERMINAL_STATUSES.has(opts.status)) {
      run.ended_at = iso;
      updatedFields.push("ended_at");
      run.current_step = null;
      appendEvent({ type: `run_${opts.status}`, step: null });
    }
  }
  (0, import_node_fs12.writeFileSync)(runYamlPath, `${RUN_YAML_MODELINE}
${(0, import_yaml8.stringify)(run)}`, "utf8");
  return { runDir, appendedEvents, updatedFields };
}

