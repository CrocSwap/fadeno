function formatAjvError(err) {
  const detail2 = err.message ?? "is invalid";
  if (err.keyword === "additionalProperties") {
    const prop = err.params.additionalProperty;
    return `unknown property "${prop}"`;
  }
  if (err.keyword === "enum") {
    const allowed = err.params.allowedValues;
    return `${detail2}: ${JSON.stringify(allowed)}`;
  }
  return detail2;
}
function schemaIssues(file, validate, doc) {
