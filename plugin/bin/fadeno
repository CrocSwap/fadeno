function slugify(text, maxLen = 40) {
  const words = text.toLowerCase().replace(/[^a-z0-9]+/g, " ").trim().split(/\s+/).filter(Boolean);
  let slug = "";
  for (const word of words) {
    const next = slug ? `${slug}-${word}` : word;
    if (next.length > maxLen) break;
    slug = next;
  }
  if (!slug && words.length) slug = words[0].slice(0, maxLen);
  return slug || "run";
}
function resolvePlaybook(playbooksDir, name) {
  const stripped = name.replace(/\.(ya?ml)$/i, "");
  for (const candidate of [`${stripped}.yaml`, `${stripped}.yml`]) {
    if ((0, import_node_fs7.existsSync)((0, import_node_path7.join)(playbooksDir, candidate))) return stripped;
  }
  throw new NewRunError(`Playbook "${stripped}" not found in ${playbooksDir}.`);
}
