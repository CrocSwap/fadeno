var ValidateError = class extends Error {
};
function runValidate(opts = {}) {
  const cwd = opts.cwd ?? process.cwd();
  const repoRoot = opts.repoRoot ?? findRepoRoot(cwd);
  const schemasDir = (0, import_node_path13.join)(repoRoot, ".fadeno", "schemas");
  if (!(0, import_node_fs13.existsSync)(schemasDir)) {
    throw new ValidateError(
      `No Fadeno schemas found at ${schemasDir}.
Run \`fadeno init --codex\` or \`fadeno init --claude\` first.`
    );
  }
  const schemas = new SchemaSet(schemasDir);
  let files;
  let forcedKind;
  if (opts.path) {
    files = [(0, import_node_path13.isAbsolute)(opts.path) ? opts.path : (0, import_node_path13.resolve)(cwd, opts.path)];
    forcedKind = opts.schema;
  } else {
    forcedKind = "playbook";
    const playbooksDir = (0, import_node_path13.join)(repoRoot, ".fadeno", "playbooks");
    if (!(0, import_node_fs13.existsSync)(playbooksDir)) {
      throw new ValidateError(`No playbooks directory at ${playbooksDir}.`);
    }
    files = (0, import_node_fs13.readdirSync)(playbooksDir).filter((f) => f.endsWith(".yaml") || f.endsWith(".yml")).sort().map((f) => (0, import_node_path13.join)(playbooksDir, f));
    if (files.length === 0) {
      throw new ValidateError(`No playbooks (*.yaml) found in ${playbooksDir}.`);
    }
  }
  const results = files.map((file) => validateFile(file, schemas, forcedKind));
  return { repoRoot, results, ok: results.every((r) => r.ok) };
