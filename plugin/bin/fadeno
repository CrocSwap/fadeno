  let runId = `${datePart}-${timePart}-${slug}`;
  let runDir = (0, import_node_path7.join)(runsDir, runId);
  for (let n = 2; (0, import_node_fs7.existsSync)(runDir); n += 1) {
    runId = `${datePart}-${timePart}-${slug}-${n}`;
