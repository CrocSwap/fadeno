{
  "name": "fadeno",
  "version": "0.4.0",
  "description": "Portable, repo-native playbook layer for AI coding agents (Codex, Claude Code).",
  "keywords": [
    "ai",
    "agents",
    "codex",
    "claude-code",
    "playbook",
    "workflow",
    "skills"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "fadeno": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "build:bin": "node scripts/build-bin.mjs",
    "build:plugin": "node src/cli.ts plugin ./plugin --force && npm run build:bin",
    "build:plugin:codex": "node src/cli.ts plugin --codex --force",
    "prepare": "npm run build",
    "dev": "node src/cli.ts",
    "test": "node --test \"test/**/*.test.ts\"",
    "eval:summary": "node evals/scripts/summarize-results.mjs --results-dir evals/results --valid-only",
    "validate:self": "node src/cli.ts validate",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
